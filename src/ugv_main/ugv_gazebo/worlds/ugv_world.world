<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <shadows>false</shadows>
    </scene>

    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose frame=''>0.319654 -0.235002 9.29441 0 1.5138 0.009599</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <include>
      <uri>model://world</uri>
      <static>1</static>
    </include>

    <!-- Door in Wall_10 gap. Hinge on +Y side of gap (world: 0.11444, 0.392487).
         Model X axis runs along the wall (yaw=-1.5708). Panel swings 0..90 deg. -->
    <model name='door_wall_10'>
      <pose>0.114440 0.392487 0 0 0 -1.5708</pose>
      <static>0</static>

      <!-- Hinge post (fixed to world) -->
      <link name='door_frame'>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>1000</mass>
          <inertia>
            <ixx>1</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1</iyy><iyz>0</iyz><izz>1</izz>
          </inertia>
        </inertial>
        <visual name='frame_visual'>
          <pose>0 0 1.25 0 0 0</pose>
          <geometry><box><size>0.05 0.15 2.5</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
          </material>
        </visual>
        <collision name='frame_collision'>
          <pose>0 0 1.25 0 0 0</pose>
          <geometry><box><size>0.05 0.15 2.5</size></box></geometry>
        </collision>
      </link>

      <!-- Door panel: link origin at hinge point, geometry offset to panel centre -->
      <link name='door_panel'>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>10</mass>
          <pose>0.475 0 1.0 0 0 0</pose>
          <inertia>
            <ixx>3.36</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.76</iyy><iyz>0</iyz><izz>3.40</izz>
          </inertia>
        </inertial>
        <visual name='panel_visual'>
          <pose>0.475 0 1.0 0 0 0</pose>
          <geometry><box><size>0.95 0.05 2.0</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <ambient>0.55 0.35 0.15 1</ambient>
            <diffuse>0.55 0.35 0.15 1</diffuse>
          </material>
        </visual>
        <collision name='panel_collision'>
          <pose>0.475 0 1.0 0 0 0</pose>
          <geometry><box><size>0.95 0.05 2.0</size></box></geometry>
        </collision>
        <!-- Door handle -->
        <visual name='handle_visual'>
          <pose>0.82 -0.05 1.0 0 0 0</pose>
          <geometry><cylinder><radius>0.015</radius><length>0.1</length></cylinder></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
      </link>

      <!-- Fix hinge post to world -->
      <joint name='frame_to_world' type='fixed'>
        <parent>world</parent>
        <child>door_frame</child>
      </joint>

      <!-- Revolute hinge: panel rotates around vertical axis at link origin -->
      <joint name='door_hinge' type='revolute'>
        <pose>0 0 0 0 0 0</pose>
        <parent>door_frame</parent>
        <child>door_panel</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>0</lower>
            <upper>1.5708</upper>
            <effort>100</effort>
            <velocity>1</velocity>
          </limit>
          <dynamics>
            <damping>5</damping>
            <friction>1</friction>
          </dynamics>
        </axis>
      </joint>
    </model>

    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <update_rate>10.0</update_rate>
    </plugin>

  </world>
</sdf>
